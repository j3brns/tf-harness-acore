    <mxCell id="61" value="Use the smallest validation lane that still covers the touched scope.\nIf the work broadens, split the issue or update scope before continuing.\nFor AWS-specific behavior, check AWS Knowledge before editing assumptions that can drift over time.\nA worktree is not finished until the PR exists, issue evidence is posted, and merge/closeout is complete." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=18;fontColor=#2E3440;" vertex="1" parent="1"><mxGeometry x="210" y="385" width="1070" height="160" as="geometry"/></mxCell>

